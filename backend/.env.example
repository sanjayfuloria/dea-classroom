# Backend Environment Variables
# Copy this file to .env and fill in your values

# Path to your Firebase Admin SDK service account JSON key
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_ADMIN_SDK_KEY=./firebase-admin-key.json

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,https://YOUR_PROJECT_ID.web.app

# Optional: used for signing tokens if you add JWT auth later
SECRET_KEY=change-me-to-a-random-secret-string
