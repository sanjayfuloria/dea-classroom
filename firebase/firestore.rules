rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read and write own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Sessions: users write/read own sessions; faculty read all
    match /sessions/{sessionId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'faculty'
      );
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Uploaded datasets: owner can read/write
    match /datasets/{datasetId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Python run history
    match /python_runs/{runId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Courses: faculty create; all authenticated can read
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'faculty';
      allow update, delete: if request.auth != null
        && resource.data.facultyId == request.auth.uid;
    }
  }
}
